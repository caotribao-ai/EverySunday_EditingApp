rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().plan == 'FREE';
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Billing plan changes are server-only via Firebase Admin.
        incoming().diff(existing()).affectedKeys().hasOnly(['lastLogin', 'displayName'])
      );

      function isValidUser(data) {
        return data.keys().hasAll(['email', 'plan', 'createdAt', 'lastLogin']) &&
               data.keys().size() >= 4 &&
               data.email is string && data.email.size() <= 200 &&
               data.plan in ['FREE', 'BASIC', 'PRO'] &&
               data.createdAt is number &&
               data.lastLogin is number;
      }
    }

    // --- Projects Collection ---
    match /projects/{projectId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidProject(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid && isValidProject(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'thumbnailUrl', 'duration', 'videoUrl'])
      );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;

      function isValidProject(data) {
        return data.keys().hasAll(['userId', 'name', 'createdAt']) &&
               data.keys().size() >= 3 &&
               data.userId == request.auth.uid &&
               data.name is string && data.name.size() <= 300 &&
               data.createdAt is number &&
               (data.get('thumbnailUrl', '') is string && data.get('thumbnailUrl', '').size() <= 1000) &&
               (data.get('duration', 0) is number);
      }
    }

    // Billing and background job records are server-owned.
    match /payment_requests/{requestId} {
      allow read, write: if false;
    }

    match /jobs/{jobId} {
      allow read, write: if false;
    }
  }
}
