# Production: NODE_ENV=production
# Never enable these on production (server will refuse to start):
# LOCAL_DEV_BYPASS_AUTH=true
# LOCAL_FULL_TEST_MODE=true

GEMINI_API_KEY=
OPENAI_API_KEY=
PEXELS_API_KEY=
APP_URL=https://your-everysunday-domain.example
GOOGLE_CLOUD_PROJECT=
ADMIN_UIDS=

# Optional payment webhook protection
SEPAY_API_KEY=

# Server tuning
PORT=3000
JOB_WORKER_CONCURRENCY=1

# Redis queue (recommended production). API enqueues; run `npm run worker` separately.
REDIS_URL=redis://127.0.0.1:6379
TRANSCRIBE_MAX_ATTEMPTS=3
EXPORT_MAX_ATTEMPTS=3
