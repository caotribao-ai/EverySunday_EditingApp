{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system, including their subscription plan.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "plan": { "type": "string", "enum": ["FREE", "BASIC", "PRO"] },
        "lastLogin": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["email", "plan"]
    },
    "Project": {
      "title": "Project",
      "description": "A video project created by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "duration": { "type": "number" },
        "createdAt": { "type": "number" },
        "videoUrl": { "type": "string" }
      },
      "required": ["userId", "name", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Individual video projects."
    }
  }
}
